{{ 'gallery.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="gallery color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin gallery__title">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}
    <slider-component class="slider-mobile-gutter">
      <ul
        class="gallery-list contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {% comment %}{%- assign empty_column = '' -%}
          {%- if block.settings.image == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' gallery-list__item--empty' -%}
          {%- endif -%}{% endcomment %}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="gallery-list__item grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="gallery-card content-container">
              
                {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                  {% assign spaced_image = true %}
                {% endif %}
                <div class="gallery-card__image-wrapper gallery-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} gallery-card-spacing{% endif %}">
                  {% assign ratio = block.settings.image.aspect_ratio | default: 1 %}

                    <div
                      class="media media--transparent media--{{ section.settings.image_ratio }}"
                      {% if section.settings.image_ratio == 'adapt' %}
                        style="padding-bottom: {{ 1 | divided_by: ratio | times: 100 }}%;"
                      {% endif %}
                    >

                    {%- liquid
                        assign number_of_columns = section.settings.columns_desktop
                        assign number_of_columns_mobile = section.settings.columns_mobile
                        assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                        assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                        assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                        if section.settings.image_width == 'half'
                          assign image_width = 0.5
                        elsif section.settings.image_width == 'third'
                          assign image_width = 0.33
                        else
                          assign image_width = 1
                        endif
                      -%}
                      {% capture sizes %}
                        (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                        (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                        (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                        calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                      {% endcapture %}

                      {%- assign img = block.settings.image -%}

{% if img != blank %}
  {{ 
    img | image_url: width: 3200 | image_tag:
      widths: '50,75,100,150,200,300,400,500,750,1000,1250,1500,1750,2000,2250,2500,2750,3000,3200',
      sizes: sizes,
      class: 'gallery-card__image open-popup'
  }}
{% else %}
  {{ 'image' | placeholder_svg_tag: 'placeholder-svg gallery-card__image' }}
{% endif %}
                      
                  </div>
                </div>
              
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="slider-buttons large-up-hide">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>
    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>


{%- if section.settings.enable_popup -%}
<div id="image-popup" class="image-popup">
  <span class="close-popup gallery-media-modal__toggle">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-close" viewBox="0 0 18 17">
      <path fill="currentColor" d="M.865 15.978a.5.5 0 0 0 .707.707l7.433-7.431 7.579 7.282a.501.501 0 0 0 .846-.37.5.5 0 0 0-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 1 0-.707-.708L8.991 7.853 1.413.573a.5.5 0 1 0-.693.72l7.563 7.268z"></path>
    </svg>
  </span>

  <div class="popup-slider-wrapper">
    

    <div class="swiper popup-swiper">
      <div class="swiper-wrapper">

      </div>
    </div>


    <div class="slider-buttons-custom">
      <button class="prev-slide">
        <svg viewBox="0 0 1024 1024" class="icon"><path d="M256 120.768L306.432 64 768 512l-461.568 448L256 903.232 659.072 512z" fill="#000"/></svg>
      </button>

      <button class="next-slide">
        <svg viewBox="0 0 1024 1024" class="icon"><path d="M768 903.232l-50.432 56.768L256 512l461.568-448 50.432 56.768L364.928 512z" fill="#000"/></svg>
      </button>
    </div>

  </div>
</div>

</div>
{%- endif -%}

<style>
.slider-buttons-custom button {
    position: absolute;
    top: 50%;
    transform: translate(0%, 0%);
    background-color: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 50%;
    color: rgba(var(--color-foreground), 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    right: 2rem;
    padding: 1.2rem;
    z-index: 2;
    width: 4rem;
    height: 4rem;
}
.slider-buttons-custom button.prev-slide {
    right: -70px;
}

.slider-buttons-custom button.next-slide {
    left: -70px;
}
.image-popup {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  text-align: center;
  align-items: center;
    justify-content: center;
}
.popup-slider-wrapper {
    max-width: 35%;
    position: relative;
}
.popup-slider-wrapper .swiper-wrapper {
    align-items: center;
}
.popup-slider {
  display: flex;
  transition: transform 0.4s ease-in-out; /* smooth slide */
}

.image-popup img {
  width: 100%;
}
.gallery-media-modal__toggle {
  background-color: rgb(var(--color-background));
  border: 0.1rem solid rgba(var(--color-foreground), 0.1);
  border-radius: 50%;
  color: rgba(var(--color-foreground), 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  right: 2rem;
  padding: 1.2rem;
  position: fixed;
  z-index: 2;
  top: 2rem;
  width: 4rem;
}
.slider-buttons-custom button svg {
    width: 2.2rem;
    height: 2.2rem;
}
@media screen and (min-width: 750px) {

  .gallery-media-modal__toggle {
    right: 5rem;
    top: 2.2rem;
  }
}
@media screen and (min-width: 990px) {

  .gallery-media-modal__toggle {
    right: 5rem;
  }
}
.gallery-media-modal__toggle:hover {
  color: rgba(var(--color-foreground), 0.75);
}
.gallery-media-modal__toggle .icon {
  height: auto;
  margin: 0;
  width: 2.2rem;
}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const popup = document.getElementById('image-popup');
  const wrapper = popup.querySelector('.swiper-wrapper');
  const closeBtn = popup.querySelector('.close-popup');

  let swiper;

  const images = Array.from(document.querySelectorAll('.open-popup'));

  images.forEach((img, index) => {
    img.addEventListener('click', function() {


      wrapper.innerHTML = images.map(i => 
        `<div class="swiper-slide">
          <img src="${i.src}" />
        </div>`
      ).join('');

      popup.style.display = 'flex';


      if (swiper) swiper.destroy(true, true);


      swiper = new Swiper('.popup-swiper', {
        initialSlide: index,
        speed: 500,
        loop: true,
        grabCursor: true,
        spaceBetween: 10,
        navigation: {
          nextEl: '.next-slide',
          prevEl: '.prev-slide',
        },
      });
    });
  });


  closeBtn.addEventListener('click', function() {
    popup.style.display = 'none';
    wrapper.innerHTML = '';
    if (swiper) swiper.destroy(true, true);
  });
});
</script>

{% schema %}
{
  "name": "t:sections.image-gallery.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.image-gallery.settings.title.default",
      "label": "t:sections.image-gallery.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-gallery.settings.header_image.content"
    },    
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.image-gallery.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.image-gallery.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.image-gallery.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.image-gallery.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.image-gallery.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.image-gallery.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.image-gallery.settings.image_ratio.options__3.label"
        },
        {
          "value": "circle",
          "label": "t:sections.image-gallery.settings.image_ratio.options__4.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.image-gallery.settings.image_ratio.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-gallery.settings.header_button.content"
    },    
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.image-gallery.settings.button_label.default",
      "label": "t:sections.image-gallery.settings.button_label.label", 
      "info": "t:sections.image-gallery.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.image-gallery.settings.button_link.label"
    },    
    {
      "type": "header",
      "content": "t:sections.image-gallery.settings.header_layout.content"
    },     
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.image-gallery.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-gallery.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-gallery.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.image-gallery.settings.column_alignment.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.image-gallery.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.image-gallery.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.image-gallery.settings.background_style.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_popup",
      "default": false,
      "label": "t:sections.image-gallery.settings.enable_popup.label"
    },    
    {
      "type": "header",
      "content": "t:sections.image-gallery.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.image-gallery.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.image-gallery.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.image-gallery.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.image-gallery.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.image-gallery.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image-gallery.blocks.column.settings.image.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-gallery.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}

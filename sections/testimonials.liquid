{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
if section.settings.enable_desktop_slider and section.blocks.size > section.settings.columns_desktop
  assign show_desktop_slider = true
endif
-%}

<div class="testimonials color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin testimonials__title">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}
    <slider-component class="slider-mobile-gutter">
      <ul
        class="testimonials-list contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider or show_desktop_slider %} slider{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% if show_desktop_slider %} slider--desktop{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.title == blank
            and block.settings.text == blank
          -%}
            {%- assign empty_column = ' testimonials-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="testimonials-list__item grid__item{% if section.settings.swipe_on_mobile or section.settings.enable_desktop_slider %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="testimonials-card content-container">

              <div class="testimonials-card__info">
              {% assign rating = block.settings.rating | plus: 0 %}
              {% if rating > 5 %}{% assign rating = 5 %}{% endif %}
              {% if rating < 0 %}{% assign rating = 0 %}{% endif %}

              <div class="rating {% if section.settings.column_alignment == 'center' %} center{% endif %}" style="column-gap:{{ block.settings.star_gap }}px;">

              {% for i in (1..5) %}

                {% assign star_value = rating | minus: i | plus: 1 %}

                {% if star_value >= 1 %}
                  {% assign fill = 100 %}
                {% elsif star_value <= 0 %}
                  {% assign fill = 0 %}
                {% else %}
                  {% assign fill = star_value | times: 100 %}
                {% endif %}

                <svg viewBox="0 0 24 24" width="20" height="20" class="star">
                  
                  <defs>
                    <linearGradient id="g{{ block.id }}{{ i }}">
                      <stop offset="{{ fill }}%" stop-color="{{ block.settings.star_active }}"/>
                      <stop offset="{{ fill }}%" stop-color="{{ block.settings.star_inactive }}"/>
                    </linearGradient>
                  </defs>

                  <path fill="url(#g{{ block.id }}{{ i }})"
                    d="M12 .7l3.6 7.3 8 .9-5.8 5.6 1.4 8-7.2-3.8-7.2 3.8 1.4-8L.4 8.9l8-.9z"/>

                </svg>

              {% endfor %}

              </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="inline-richtext">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                  <div class="reviewer {% if section.settings.column_alignment == 'center' %} center{% endif %}" style="column-gap:{{ block.settings.author_gap }}px;">

                    {% if block.settings.reviewer_photo != blank %}
                      
                      {{ block.settings.reviewer_photo 
                        | image_url: width: 80 
                        | image_tag: class: 'reviewer__img' }}

                    {% else %}

                      {% assign first = block.settings.reviewer_name | slice: 0,1 | upcase %}

                      <div class="reviewer__avatar"
                           style="
                             background: {{ block.settings.avatar_bg }};
                             color: {{ block.settings.avatar_text }};
                           ">
                        {{ first }}
                      </div>

                    {% endif %}

                    <span class="reviewer__name">
                      {{ block.settings.reviewer_name }}
                    </span>

                  </div>
                </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons{% unless show_desktop_slider == true %} large-up-hide{% endunless %}">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.testimonials.settings.title.default",
      "label": "t:sections.testimonials.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },    
    {
      "type": "header",
      "content": "t:sections.testimonials.settings.header_layout.content"
    },     
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.testimonials.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.testimonials.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.testimonials.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.testimonials.settings.column_alignment.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.testimonials.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.testimonials.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.testimonials.settings.background_style.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },    
    {
      "type": "header",
      "content": "t:sections.testimonials.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.testimonials.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.testimonials.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.testimonials.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "default": false,
      "label": "t:sections.testimonials.settings.enable_desktop_slider.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.testimonials.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.testimonials.blocks.column.name",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.column.settings.rating.label",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "default": 5
        },
        {
          "type": "range",
          "id": "star_gap",
          "label": "t:sections.testimonials.blocks.column.settings.star_gap.label",
          "min": 0,
          "max": 20,
          "step": 1,
          "default": 8
        },
        {
          "type": "color",
          "id": "star_active",
          "label": "t:sections.testimonials.blocks.column.settings.star_active.label",
          "default": "#f5a623"
        },
        {
          "type": "color",
          "id": "star_inactive",
          "label": "t:sections.testimonials.blocks.column.settings.star_inactive.label",
          "default": "#d2d5d9"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "t:sections.testimonials.blocks.column.settings.title.default",
          "label": "t:sections.testimonials.blocks.column.settings.title.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "t:sections.testimonials.blocks.column.settings.text.default",
          "label": "t:sections.testimonials.blocks.column.settings.text.label"
        },
        {
          "type": "image_picker",
          "id": "reviewer_photo",
          "label": "t:sections.testimonials.blocks.column.settings.reviewer_photo.label"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "t:sections.testimonials.blocks.column.settings.reviewer_name.label",
          "default": "t:sections.testimonials.blocks.column.settings.reviewer_name.default"
        },
        {
          "type": "number",
          "id": "author_gap",
          "label": "t:sections.testimonials.blocks.column.settings.author_gap.label",
          "default": 8
        },
        {
          "type": "color",
          "id": "avatar_bg",
          "label": "t:sections.testimonials.blocks.column.settings.avatar_bg.label",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "avatar_text",
          "label": "t:sections.testimonials.blocks.column.settings.avatar_text.label",
          "default": "#fff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}